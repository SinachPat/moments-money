# Flow Network
NEXT_PUBLIC_FLOW_NETWORK=testnet                  # testnet | mainnet

# Contract Addresses
NEXT_PUBLIC_MOMENTS_MONEY_ADDRESS=0x             # Deployed MomentsMoney contract address

# Explorer
NEXT_PUBLIC_FLOWSCAN_URL=https://testnet.flowscan.org  # Switch to https://flowscan.org for mainnet

# Off-chain Services
FLOOR_PRICE_UPDATE_INTERVAL_MS=300000            # How often to update floor prices (ms), default 5min
FLOWVERSE_API_KEY=                               # API key for Flowverse NFT data

# Admin (Server-side only — NEVER expose to frontend)
ADMIN_PRIVATE_KEY=                               # Never commit this
